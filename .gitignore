# ══════════════════════════════════════════════════════════════════════════════
# GU Commerce Platform — .gitignore
# Covers: Terraform, Python Lambda, HTML Frontend, AWS, VS Code, Windows
# ══════════════════════════════════════════════════════════════════════════════


# ── Terraform ─────────────────────────────────────────────────────────────────

# Local .terraform directory (provider plugins — re-downloaded via terraform init)
.terraform/
.terraform.lock.hcl

# Terraform state files — contain sensitive infrastructure details
terraform.tfstate
terraform.tfstate.backup
terraform.tfstate.d/

# Terraform plan output files
*.tfplan
*.tfplan.json

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
# Exception: keep example var files if you have them
!example.tfvars
!*.tfvars.example

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json


# ── Lambda ZIP files (auto-generated by Terraform archive_file) ───────────────

guproduct/lambda_function.zip
gucart/lambda_function.zip
gurecommend/lambda_function.zip
gulogu/lambda_auth.zip

# Catch any other auto-generated zips
*.zip


# ── Python ────────────────────────────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# pytest cache
.pytest_cache/
.cache/

# Coverage reports
.coverage
.coverage.*
htmlcov/
coverage.xml
tests/coverage_report/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# Unit test logs
*.log


# ── Environment & Secrets ─────────────────────────────────────────────────────

# Environment variable files — NEVER commit secrets
.env
.env.*
!.env.example

# AWS credentials — should always use IAM roles or profiles, never hardcode
.aws/
aws-credentials.json

# Any key or certificate files
*.pem
*.key
*.p12
*.pfx


# ── Frontend ──────────────────────────────────────────────────────────────────

# No build tools used (plain HTML/CSS/JS) — nothing to ignore here
# but keep OS/editor artifacts out:


# ── VS Code ───────────────────────────────────────────────────────────────────

.vscode/
# Exception: keep shared settings if your team uses them
!.vscode/extensions.json
!.vscode/settings.json.example


# ── Windows ───────────────────────────────────────────────────────────────────

Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Windows shortcut files
*.lnk


# ── macOS ─────────────────────────────────────────────────────────────────────

.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes


# ── JetBrains IDEs ────────────────────────────────────────────────────────────

.idea/
*.iml


# ── Node (if ever added) ──────────────────────────────────────────────────────

node_modules/
npm-debug.log*


# ── Misc ──────────────────────────────────────────────────────────────────────

# Backup files
*.bak
*.tmp
*.swp
*.swo
*~

# OS generated
.directory